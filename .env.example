@'
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace_me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Имя django-проекта (папка, где settings.py). Обычно "config" или название твоего проекта.
DJANGO_PROJECT=config

# Порты хоста
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_HOST=db

# Redis
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0
'@ | Set-Content .env.example -Encoding UTF8

Copy-Item .env.example .env -Force
